{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness.project-pack.v1",
  "type": "object",
  "required": ["schema_version", "id", "paths"],
  "properties": {
    "schema_version": {"const": "harness.project-pack.v1"},
    "id": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "links": {"type": "object", "additionalProperties": {"type": "string"}},
    "exclude": {"type": "array", "items": {"type": "string"}},
    "tombstones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!\\.{1,2}$)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
          },
          "accepted_sha256": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "minItems": 1,
            "uniqueItems": true
          },
          "accepted_symlink_targets": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "anyOf": [
          {"required": ["accepted_sha256"]},
          {"required": ["accepted_symlink_targets"]}
        ],
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "settings_merges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "format", "operation", "path", "match", "append_path", "value"],
        "properties": {
          "target": {"type": "string", "minLength": 1},
          "format": {"const": "json"},
          "operation": {"const": "append-if-missing"},
          "path": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "match": {"type": "object"},
          "append_path": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "value": {"type": "object"}
        },
        "additionalProperties": false
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness.execution.v1",
  "type": "object",
  "required": ["schema_version", "execution_id", "objective", "state", "attempt", "success_criteria", "artifact_root", "evidence", "checks", "history"],
  "properties": {
    "schema_version": {"const": "harness.execution.v1"},
    "execution_id": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "state": {"enum": ["pending", "running", "succeeded", "failed", "blocked", "needs_approval"]},
    "attempt": {"type": "integer", "minimum": 0},
    "success_criteria": {"type": "array", "items": {"type": "string"}},
    "artifact_root": {"const": "artifacts"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description", "producer", "command", "exit_code", "status", "path", "sha256", "bytes"],
        "properties": {
          "type": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "producer": {"type": "string", "minLength": 1},
          "command": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "exit_code": {"type": "integer"},
          "status": {"enum": ["passed", "failed"]},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "checks": {"type": "array", "items": {"type": "object", "required": ["criterion", "status"]}},
    "stop_reason": {"type": ["string", "null"]},
    "history": {"type": "array", "items": {"type": "object"}}
  }
}

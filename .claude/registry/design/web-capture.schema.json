{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-craft.local/schemas/design-web-capture-v1.json",
  "title": "Web Design Capture Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "base_url", "cases"],
  "properties": {
    "schema": {"const": "design-web-capture-v1"},
    "base_url": {"type": "string", "format": "uri"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "state", "viewport"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
          "path": {"type": "string"},
          "state": {"type": "string"},
          "phase": {"enum": ["baseline", "result"]},
          "viewport": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "width", "height"],
            "properties": {
              "name": {"type": "string"},
              "width": {"type": "integer", "minimum": 240},
              "height": {"type": "integer", "minimum": 240},
              "device_scale_factor": {"type": "number", "exclusiveMinimum": 0}
            }
          },
          "wait_until": {"enum": ["commit", "domcontentloaded", "load", "networkidle"]},
          "wait_for_selector": {"type": "string"},
          "timeout_ms": {"type": "integer", "minimum": 1},
          "settle_ms": {"type": "integer", "minimum": 0},
          "full_page": {"type": "boolean"},
          "reduced_motion": {"type": "boolean"},
          "capture_aria": {"type": "boolean"},
          "allow_console_errors": {"type": "boolean"},
          "supports": {"type": "array", "items": {"type": "string"}},
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "selector"],
              "properties": {
                "type": {"enum": ["click", "fill", "press"]},
                "selector": {"type": "string"},
                "value": {"type": "string"},
                "key": {"type": "string"}
              }
            }
          },
          "assertions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type"],
              "properties": {
                "type": {"enum": ["visible", "text", "aria_contains"]},
                "selector": {"type": "string", "minLength": 1},
                "value": {"type": "string", "minLength": 1},
                "match": {"enum": ["contains", "exact"]}
              },
              "allOf": [
                {
                  "if": {"properties": {"type": {"enum": ["visible", "text"]}}},
                  "then": {"required": ["selector"]}
                },
                {
                  "if": {"properties": {"type": {"enum": ["text", "aria_contains"]}}},
                  "then": {"required": ["value"]}
                }
              ]
            }
          }
        },
        "allOf": [
          {
            "if": {
              "required": ["state"],
              "properties": {"state": {"not": {"const": "default"}}}
            },
            "then": {
              "required": ["assertions"],
              "properties": {"assertions": {"minItems": 1}}
            }
          }
        ]
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-craft.local/schemas/design-critic-result-v1.json",
  "title": "Independent Design Critic Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "run_id", "critic_id", "independent", "actor", "round", "review_packet", "review_packet_sha256", "evidence_ids", "findings", "rubric_scores", "decision"],
  "properties": {
    "schema": { "const": "design-critic-result-v1" },
    "run_id": { "type": "string" },
    "critic_id": { "type": "string", "minLength": 1 },
    "independent": { "const": true },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "role", "implementation_actor_id", "context_manifest", "context_manifest_sha256", "issued_at"],
      "properties": {
        "actor_id": {"type": "string", "minLength": 1},
        "role": {"const": "independent_critic"},
        "implementation_actor_id": {"type": "string", "minLength": 1},
        "context_manifest": {"type": "string", "minLength": 1},
        "context_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "issued_at": {"type": "string", "format": "date-time"}
      }
    },
    "round": { "type": "integer", "minimum": 0, "maximum": 2 },
    "review_packet": {"type": "string", "minLength": 1},
    "review_packet_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "evidence_ids": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "axis", "observation", "evidence_ids", "repair"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "enum": ["critical", "major", "minor", "suggestion"] },
          "axis": { "enum": ["register-fit", "usability", "states", "evidence", "craft", "accessibility", "distinctiveness", "performance"] },
          "observation": { "type": "string", "minLength": 10 },
          "evidence_ids": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
          "repair": { "type": "string", "minLength": 3 }
        }
      }
    },
    "rubric_scores": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["score", "evidence", "rationale"],
        "properties": {
          "score": {"type": "number", "minimum": 0, "maximum": 10},
          "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
          "rationale": {"type": "string", "minLength": 10}
        }
      }
    },
    "excluded_signals": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "decision": { "enum": ["pass", "repair", "fail", "blocked"] },
    "summary": { "type": "string" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-craft.local/schemas/design-flutter-capture-v1.json",
  "title": "Flutter Design Capture Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "test_targets", "generated_artifact_root", "artifacts"],
  "properties": {
    "schema": {"const": "design-flutter-capture-v1"},
    "test_targets": {"type": "array", "items": {"type": "string"}},
    "generated_artifact_root": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "path", "screen", "state", "viewport", "supports"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {"enum": ["baseline-screenshot", "result-screenshot", "accessibility-tree"]},
          "path": {"type": "string"},
          "screen": {"type": "string"},
          "state": {"type": "string"},
          "viewport": {"type": "string"},
          "supports": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        }
      }
    }
  }
}

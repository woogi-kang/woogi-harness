{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-craft.local/schemas/design-capture-index-v1.json",
  "title": "Design Platform Capture Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "producer", "generated_at", "platform", "project_root", "spec", "spec_sha256", "run_id", "nonce", "adapter_sha256", "source_fingerprint_digest", "status", "results"],
  "properties": {
    "schema": {"const": "design-capture-index-v1"},
    "producer": {"enum": ["capture-web-evidence@1", "capture-flutter-evidence@1"]},
    "generated_at": {"type": "string", "format": "date-time"},
    "platform": {"enum": ["web", "flutter"]},
    "project_root": {"type": "string", "minLength": 1},
    "spec": {"type": "string", "minLength": 1},
    "spec_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "run_id": {"type": "string", "minLength": 6},
    "nonce": {"type": "string", "pattern": "^[a-f0-9]{48}$"},
    "adapter_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_fingerprint_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "status": {"enum": ["passed", "failed"]},
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "artifacts"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"enum": ["passed", "failed"]},
          "errors": {"type": "array", "items": {"type": "string"}},
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "path", "sha256", "platform", "supports"],
              "properties": {
                "kind": {"enum": ["baseline-screenshot", "result-screenshot", "accessibility-tree", "state-assertion", "test-log"]},
                "path": {"type": "string"},
                "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                "route": {"type": "string"},
                "state": {"type": "string"},
                "viewport": {"type": "string"},
                "platform": {"enum": ["web", "flutter"]},
                "supports": {"type": "array", "minItems": 1, "items": {"type": "string"}}
              }
            }
          }
        }
      }
    }
  }
}

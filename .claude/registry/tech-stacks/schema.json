{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-craft.local/schemas/tech-stack-registry-v1.json",
  "title": "Claude Craft tech stack registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "display_name",
    "verified_at",
    "policy",
    "components",
    "migration",
    "promotion_gates",
    "consumers"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "display_name": { "type": "string", "minLength": 1 },
    "verified_at": { "type": "string", "format": "date" },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_channel", "upgrade_rule"],
      "properties": {
        "default_channel": { "enum": ["recommended"] },
        "upgrade_rule": { "type": "string", "minLength": 1 }
      }
    },
    "components": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/component" }
    },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guide", "summary"],
      "properties": {
        "guide": { "type": "string", "pattern": "^migrations/.+\\.md$" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "consumers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "versionChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "channel"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "channel": { "enum": ["stable", "current", "lts", "beta", "rc", "candidate"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latest_observed",
        "recommended",
        "compatibility_floor",
        "prerelease",
        "verified_at",
        "source",
        "migration",
        "promotion_gates",
        "consumers"
      ],
      "properties": {
        "latest_observed": { "$ref": "#/$defs/versionChannel" },
        "recommended": { "$ref": "#/$defs/versionChannel" },
        "compatibility_floor": { "$ref": "#/$defs/versionChannel" },
        "prerelease": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/versionChannel" }
          ]
        },
        "verified_at": { "type": "string", "format": "date" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "url"],
          "properties": {
            "kind": { "enum": ["official-release", "npm", "pypi", "pub"] },
            "url": { "type": "string", "format": "uri" }
          }
        },
        "migration": {
          "type": "object",
          "additionalProperties": false,
          "required": ["guide", "note"],
          "properties": {
            "guide": { "type": "string", "pattern": "^migrations/.+\\.md$" },
            "note": { "type": "string", "minLength": 1 }
          }
        },
        "promotion_gates": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "consumers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}

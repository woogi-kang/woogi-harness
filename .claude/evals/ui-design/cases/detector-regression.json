      "expected_ids": ["default-shadcn-card"]
    },
    {
      "id": "generic-copy-and-cta",
      "extension": ".tsx",
      "source": "<section><h1>Elevate your next-gen workflow</h1><button>Get Started</button></section>",
      "expected_ids": ["cliche-copy", "generic-cta"]

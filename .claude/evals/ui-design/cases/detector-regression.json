{
  "schema": "design-slop-detector-cases-v1",
  "cases": [
    {
      "id": "clean-operational-list",
      "extension": ".tsx",
      "source": "export function Queue({ rows }) { return <main><h1>Review queue</h1><table><thead><tr><th>Owner</th><th>Status</th></tr></thead><tbody>{rows.map((row) => <tr key={row.id}><td>{row.owner}</td><td>{row.status}</td></tr>)}</tbody></table></main> }",
      "expected_ids": [],
      "exact": true
    },
    {
      "id": "hard-lorem-placeholder",
      "extension": ".html",
      "source": "<section><h2>Lorem ipsum</h2><p>dolor sit amet</p></section>",
      "expected_ids": ["lorem"]
    },
    {
      "id": "purple-gradient-reflex",
      "extension": ".tsx",
      "source": "export const Hero = () => <section className=\"bg-gradient-to-r from-purple-600 to-blue-500\"><h1>AI workspace</h1></section>",
      "expected_ids": ["ai-gradient"]
    },
    {
